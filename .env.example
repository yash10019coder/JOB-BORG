# Copy to .env and adjust for your environment.
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# Postgres (matches the `db` service in docker-compose.yml)
DATABASE_URL=postgres://jobborg:jobborg@db:5432/jobborg

# Redis (Celery broker + result backend; matches the `redis` service)
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Django cache (rematch debounce token store)
CACHE_URL=redis://redis:6379/3
